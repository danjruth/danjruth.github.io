@inproceedings{micheli_seasonal_2017,
	address = {Washington, DC},
	title = {Seasonal {Trends} of {Soiling} on {Photovoltaic} {Systems}},
	isbn = {978-1-5090-5605-7},
	url = {https://ieeexplore.ieee.org/document/8366381/},
	doi = {10.1109/PVSC.2017.8366381},
	abstract = {This work investigates the seasonal variability of photovoltaic soiling losses over a 12-month period for 15 soiling stations deployed in the USA. We present a new parameter able to rank the sites according to the cumulative losses occurring over 3and 6- month periods. The relations between soiling losses and particulate matter are briefly discussed, as well. Moving from long-term to shorter-term data increases the complexity of the analysis: monthly correlations are found to have lower accuracy than the longer-term ones presented in the literature.},
