@article{oconnor_optimization_2017,
	title = {Optimization of an {Advanced} {Combustion} {Strategy} {Towards} 55\% {BTE} for the {Volvo} {SuperTruck} {Program}},
	volume = {10},
	issn = {1946-3944},
	url = {https://www.sae.org/content/2017-01-0723/},
	doi = {10.4271/2017-01-0723},
	abstract = {This paper describes a novel design and verification process for analytical methods used in the development of advanced combustion strategies in internal combustion engines (ICE). The objective was to improve brake thermal efficiency (BTE) as part of the US Department of Energy SuperTruck program. The tools and methods herein discussed consider spray formation and injection schedule along with piston bowl design to optimize combustion efficiency, air utilization, heat transfer, emission, and BTE. The methodology uses a suite of tools to optimize engine performance, including 1D engine simulation, high-fidelity CFD, and lab-scale fluid mechanic experiments. First, a wide range of engine operating conditions are analyzed using 1-D engine simulations in GT Power to thoroughly define a baseline for the chosen advanced engine concept; secondly, an optimization and down-select step is completed where further improvements in engine geometries and spray configurations are considered. Next, simultaneous high-fidelity simulation using StarCD and OpenFOAM as well as lab-scale unsteady jet mixing experiments are used to understand the interplay between fuel injection and piston bowl designs. A key to the success of this design and analysis process is the accuracy of both the 1-D and high-fidelity simulations; these tools have been significantly improved and benchmarked against a range of engine operating conditions throughout the program. We conclude by outlining future directions for this methodology.},
	language = {en},
	number = {3},
	urldate = {2022-07-28},
	journal = {SAE International Journal of Engines},
	author = {O'Connor, Jacqueline and Borz, Meghan and Ruth, Daniel and Han, Jun and Paul, Chandan and Imren, Abdurrahman and Haworth, Daniel and Martin, Jonathan and Boehman, Andre and Li, Jian and Heffelfinger, Kevin and McLaughlin, Samuel and Morton, Richard and Andersson, Arne and Karlsson, Anders},
	month = mar,
	year = {2017},
	pages = {1217--1227},
	file = {O'Connor et al. - 2017 - Optimization of an Advanced Combustion Strategy To.pdf:/Users/danielruth/Zotero/storage/UJCHHMGG/O'Connor et al. - 2017 - Optimization of an Advanced Combustion Strategy To.pdf:application/pdf},
}

